{
  "name": "coincompass",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "description": "Turn your CoinStats crypto portfolio into an interactive world map showing how you'd live in every country — from King to Homeless.",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "data": "node scripts/build-countries-data.mjs",
    "predeploy": "npm run build",
    "deploy": "gh-pages -d dist --dotfiles -m \"Deploy site\""
  },
  "dependencies": {
    "d3-geo": "^3.1.1",
    "flag-icons": "^7.2.3",
    "framer-motion": "^11.11.17",
    "lucide-react": "^0.460.0",
    "react": "^18.3.1",
    "react-countup": "^6.5.3",
    "react-dom": "^18.3.1",
    "react-simple-maps": "^3.0.0"
  },
  "devDependencies": {
    "@types/d3-geo": "^3.1.0",
    "@types/node": "^22.9.0",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@types/react-simple-maps": "^3.0.6",
    "@types/topojson-client": "^3.1.5",
    "@vitejs/plugin-react": "^4.3.3",
    "gh-pages": "^6.3.0",
    "i18n-iso-countries": "^7.13.0",
    "playwright": "^1.60.0",
    "topojson-client": "^3.1.0",
    "typescript": "^5.6.3",
    "vite": "^5.4.11",
    "world-atlas": "^2.0.2"
  }
}
